{
  "name": "realtime-translator-agent",
  "version": "1.0.0",
  "description": "Real-Time simultaneous translation desktop subtitle overlay MVP using Electron, React, Deepgram, and OpenAI",
  "main": "src/main/main.js",
  "type": "commonjs",
  "scripts": {
    "dev:renderer": "vite",
    "dev:electron": "electron .",
    "dev": "concurrently \"npm run dev:renderer\" \"wait-on http://127.0.0.1:5173 && npm run dev:electron\"",
    "build": "vite build"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "openai": "^4.55.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^8.2.2",
    "electron": "^31.3.0",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "vite": "^5.4.2",
    "wait-on": "^7.2.0"
  }
}
