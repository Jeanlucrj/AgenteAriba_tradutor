# Copie este arquivo para .env e preencha com suas chaves reais
DEEPGRAM_API_KEY=your_deepgram_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# DeepL — tradução principal (fallback automático para Gemini se não configurado)
# Obter em: https://www.deepl.com/pro-api  |  Free: 1 milhão de chars/mês grátis
# Chave Free termina em ":fx" → usa endpoint api-free.deepl.com automaticamente
DEEPL_API_KEY=your_deepl_api_key_here

# Supabase — histórico de conversas
SUPABASE_URL=https://your_project_id.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your_key_here
